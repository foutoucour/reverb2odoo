<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ gear_name }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0e0f14;
      --card:      #13151c;
      --surface:   #1c1f2b;
      --surface2:  #181b26;
      --border:    #252836;
      --border2:   #1e2130;
      --accent:    #7b61ff;
      --gold:      #f0a732;
      --teal:      #2dd4bf;
      --text:      #e4e6f0;
      --text-dim:  #8890a8;
      --text-mute: #434a5e;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: var(--bg);
      min-height: 100vh;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding: 48px 16px;
    }

    .card {
      background: var(--card);
      width: 100%;
      max-width: 720px;
      box-shadow: 0 2px 8px rgba(0,0,0,.5), 0 24px 64px rgba(0,0,0,.7);
      border: 1px solid var(--border);
    }

    /* ── Photo ── */
    .photos {
      width: 100%;
      max-height: 480px;
      overflow: hidden;
      background: #080a10;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    .photos img {
      width: 100%;
      max-height: 480px;
      object-fit: cover;
      display: block;
      filter: brightness(.9) contrast(1.08) saturate(1.1);
    }
    .photos-empty {
      width: 100%;
      height: 220px;
      background: var(--surface);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-mute);
      font-size: 0.85rem;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    /* ── Header ── */
    .header {
      padding: 36px 40px 32px;
      border-bottom: 1px solid var(--border);
      background: linear-gradient(135deg, #13151c 0%, #181b28 100%);
    }
    .title {
      font-size: 2rem;
      font-weight: 300;
      color: var(--text);
      letter-spacing: -.02em;
      line-height: 1.15;
    }
    .title strong {
      font-weight: 700;
      background: linear-gradient(90deg, var(--accent), var(--teal));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Body ── */
    .body { padding: 0 40px 40px; }

    /* ── Section ── */
    .section { padding-top: 32px; }
    .section-title {
      font-size: 0.62rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .18em;
      color: var(--gold);
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .section-title::after {
      content: "";
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, var(--border) 0%, transparent 100%);
    }

    /* Tiles */
    .specs {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
    }
    .spec {
      background: var(--surface);
      padding: 14px 18px;
      transition: background .15s;
    }
    .spec-label {
      font-size: 0.62rem;
      color: var(--text-mute);
      text-transform: uppercase;
      letter-spacing: .1em;
    }
    .spec-value {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--teal);
      margin-top: 5px;
    }

    /* Rows (measurements, materials) */
    .rows { border: 1px solid var(--border); }
    .mrow {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding: 11px 18px;
      border-bottom: 1px solid var(--border2);
    }
    .mrow:last-child { border-bottom: none; }
    .mrow:nth-child(even) { background: var(--surface2); }
    .mrow-label {
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: .08em;
      flex-shrink: 0;
      margin-right: 24px;
    }
    .mrow-value {
      font-size: 0.9rem;
      color: var(--text);
      text-align: right;
      white-space: pre-line;
    }

    /* Footer */
    .footer {
      padding: 14px 40px;
      border-top: 1px solid var(--border);
      font-size: 0.68rem;
      color: var(--text-mute);
      letter-spacing: .06em;
      text-align: right;
      background: linear-gradient(135deg, #13151c 0%, #181b28 100%);
    }
  </style>
</head>
<body>
  <div class="card">

    {# Photo #}
    {% if photos %}
    <div class="photos">
      <img src="data:image/jpeg;base64,{{ photos[0] }}" alt="gear photo" />
    </div>
    {% else %}
    <div class="photos-empty">No photo</div>
    {% endif %}

    <div class="header">
      <div class="title">
        {{ brand }}{% if model_name %} <strong>{{ model_name }}</strong>{% endif %}
      </div>
    </div>

    <div class="body">
      {% for group in spec_groups %}
      <div class="section">
        <div class="section-title">{{ group.title }}</div>
        {% if group.style == "rows" %}
        <div class="rows">
          {% for label, value in group.specs %}
          <div class="mrow">
            <span class="mrow-label">{{ label }}</span>
            <span class="mrow-value">{{ value | replace("\n", "<br>") | safe }}</span>
          </div>
          {% endfor %}
        </div>
        {% else %}
        <div class="specs">
          {% for label, value in group.specs %}
          <div class="spec">
            <div class="spec-label">{{ label }}</div>
            <div class="spec-value">{{ value }}</div>
          </div>
          {% endfor %}
        </div>
        {% endif %}
      </div>
      {% endfor %}

      {# ── Weight gauge ── #}
      {% if weight_lbs > 0 %}
      {% set WMN  = 5.0 %}
      {% set WMX  = 11.0 %}
      {% set TL   = 48 %}
      {% set TR   = 352 %}
      {% set TW   = TR - TL %}
      {% set TY   = 46 %}
      {% set TH   = 8 %}
      {% set CLW  = [weight_lbs, WMN] | max %}
      {% set CLW  = [CLW, WMX] | min %}
      {% set PCT  = (CLW - WMN) / (WMX - WMN) %}
      {% set MX   = TL + PCT * TW %}
      {% set WDISP = weight_lbs | round(1) %}
      <div class="section">
        <div class="section-title">Weight</div>
        <svg viewBox="0 0 400 78"
             style="width:100%;display:block"
             xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="wgrad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%"   stop-color="#2dd4bf"/>
              <stop offset="45%"  stop-color="#f0a732"/>
              <stop offset="100%" stop-color="#ef4444"/>
            </linearGradient>
            <clipPath id="wclip">
              <rect x="{{ TL }}" y="{{ TY - TH / 2 }}" width="{{ PCT * TW }}" height="{{ TH }}" rx="4"/>
            </clipPath>
          </defs>

          {# Track background #}
          <rect x="{{ TL }}" y="{{ TY - TH / 2 }}" width="{{ TW }}" height="{{ TH }}" rx="4" fill="#1c1f2b"/>

          {# Gradient fill up to marker position #}
          <rect x="{{ TL }}" y="{{ TY - TH / 2 }}" width="{{ TW }}" height="{{ TH }}" rx="4"
                fill="url(#wgrad)" clip-path="url(#wclip)"/>

          {# Tick marks and labels #}
          {% for i in range(7) %}
          {% set TX = TL + i / 6.0 * TW %}
          <line x1="{{ TX }}" y1="{{ TY + TH / 2 }}" x2="{{ TX }}" y2="{{ TY + TH / 2 + 5 }}"
                stroke="#434a5e" stroke-width="1"/>
          <text x="{{ TX }}" y="{{ TY + TH / 2 + 16 }}" text-anchor="middle"
                font-size="9" fill="#434a5e"
                font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif">{{ 5 + i }}</text>
          {% endfor %}

          {# Range labels #}
          <text x="{{ TL }}" y="{{ TY + TH / 2 + 28 }}" text-anchor="middle"
                font-size="8" fill="#2dd4bf" letter-spacing=".5"
                font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif">LIGHT</text>
          <text x="{{ TR }}" y="{{ TY + TH / 2 + 28 }}" text-anchor="middle"
                font-size="8" fill="#ef4444" letter-spacing=".5"
                font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif">HEAVY</text>

          {# Marker stem #}
          <line x1="{{ MX }}" y1="{{ TY - TH / 2 - 2 }}" x2="{{ MX }}" y2="{{ TY - TH / 2 - 10 }}"
                stroke="#e4e6f0" stroke-width="1.5"/>

          {# Marker triangle (pointing down) #}
          <polygon points="{{ MX }},{{ TY - TH / 2 - 1 }} {{ MX - 5 }},{{ TY - TH / 2 - 10 }} {{ MX + 5 }},{{ TY - TH / 2 - 10 }}"
                   fill="#e4e6f0"/>

          {# Weight label #}
          <text x="{{ MX }}" y="{{ TY - TH / 2 - 14 }}" text-anchor="middle"
                font-size="9.5" font-weight="700" fill="#e4e6f0"
                font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif">{{ WDISP }} lbs</text>
        </svg>
      </div>
      {% endif %}

      {# ── Neck Profile diagram ── #}
      {% if neck_profile and neck_profile.nut_width_mm > 0 %}
      {% set NW   = neck_profile.nut_width_mm %}
      {% set T1   = neck_profile.thickness_1st_mm %}
      {% set T12  = neck_profile.thickness_12th_mm %}
      {% set SC   = 110.0 / NW %}
      {% set W    = 110 %}
      {% set H1   = T1  * SC %}
      {% set H2   = T12 * SC %}
      {% if H1 >= H2 %}{% set MH = H1 %}{% else %}{% set MH = H2 %}{% endif %}
      {% set PL   = 90 %}
      {% set PT   = 36 %}
      {% set GAP  = 56 %}
      {% set DG   = 16 %}
      {% set FH   = 5  %}
      {% set X1   = PL %}
      {% set X2   = PL + W + GAP %}
      {% set YT   = PT %}
      {% set SVW  = PL + W + GAP + W + PL %}
      {% set SVH  = PT + MH + FH + DG + 36 %}
      <div class="section">
        <div class="section-title">Neck Profile</div>
        <svg viewBox="0 0 {{ SVW }} {{ SVH }}"
             style="width:100%;max-width:480px;display:block;margin:0 auto"
             xmlns="http://www.w3.org/2000/svg">
          <defs>
            <marker id="ah" viewBox="0 0 10 10" refX="5" refY="5"
                    markerWidth="5" markerHeight="5" orient="auto-start-reverse">
              <path d="M 0 1 L 9 5 L 0 9 Z" fill="#f0a732"/>
            </marker>
          </defs>

          {# ── 1st Fret ── #}
          <text x="{{ X1 + W / 2 }}" y="{{ YT - 10 }}"
                text-anchor="middle" font-size="9" letter-spacing="1.5" fill="#f0a732" font-weight="700"
                font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif">1ST FRET</text>
          <path d="M {{ X1 }} {{ YT + FH }} L {{ X1 + W }} {{ YT + FH }} A {{ W / 2 }} {{ H1 }} 0 0 1 {{ X1 }} {{ YT + FH }} Z"
                fill="none" stroke="#3d2010" stroke-width="1.2"/>
          <rect x="{{ X1 }}" y="{{ YT }}" width="{{ W }}" height="{{ FH }}" fill="#2a1208" rx="1"/>
          {% set DY1 = YT + FH + H1 + DG %}
          <line x1="{{ X1 }}" y1="{{ YT + FH + H1 }}" x2="{{ X1 }}" y2="{{ DY1 + 2 }}" stroke="#f0a732" stroke-width="0.7" stroke-dasharray="3 2"/>
          <line x1="{{ X1 + W }}" y1="{{ YT + FH + H1 }}" x2="{{ X1 + W }}" y2="{{ DY1 + 2 }}" stroke="#f0a732" stroke-width="0.7" stroke-dasharray="3 2"/>
          <line x1="{{ X1 }}" y1="{{ DY1 }}" x2="{{ X1 + W }}" y2="{{ DY1 }}" stroke="#f0a732" stroke-width="1" marker-start="url(#ah)" marker-end="url(#ah)"/>
          <text x="{{ X1 + W / 2 }}" y="{{ DY1 + 13 }}" text-anchor="middle" font-size="9" fill="#8890a8"
                font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif">{{ neck_profile.nut_width_disp }}</text>
          {% set LX1 = X1 - DG %}
          <line x1="{{ X1 }}" y1="{{ YT + FH }}" x2="{{ LX1 - 2 }}" y2="{{ YT + FH }}" stroke="#f0a732" stroke-width="0.7" stroke-dasharray="3 2"/>
          <line x1="{{ X1 }}" y1="{{ YT + FH + H1 }}" x2="{{ LX1 - 2 }}" y2="{{ YT + FH + H1 }}" stroke="#f0a732" stroke-width="0.7" stroke-dasharray="3 2"/>
          <line x1="{{ LX1 }}" y1="{{ YT + FH }}" x2="{{ LX1 }}" y2="{{ YT + FH + H1 }}" stroke="#f0a732" stroke-width="1" marker-start="url(#ah)" marker-end="url(#ah)"/>
          <text x="{{ LX1 - 5 }}" y="{{ YT + FH + H1 / 2 + 3 }}" text-anchor="end" font-size="9" fill="#8890a8"
                font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif">{{ neck_profile.thickness_1st_disp }}</text>

          {# ── 12th Fret ── #}
          <text x="{{ X2 + W / 2 }}" y="{{ YT - 10 }}"
                text-anchor="middle" font-size="9" letter-spacing="1.5" fill="#f0a732" font-weight="700"
                font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif">12TH FRET</text>
          <path d="M {{ X2 }} {{ YT + FH }} L {{ X2 + W }} {{ YT + FH }} A {{ W / 2 }} {{ H2 }} 0 0 1 {{ X2 }} {{ YT + FH }} Z"
                fill="none" stroke="#3d2010" stroke-width="1.2"/>
          <rect x="{{ X2 }}" y="{{ YT }}" width="{{ W }}" height="{{ FH }}" fill="#2a1208" rx="1"/>
          {% set RX2 = X2 + W + DG %}
          <line x1="{{ X2 + W }}" y1="{{ YT + FH }}" x2="{{ RX2 + 2 }}" y2="{{ YT + FH }}" stroke="#f0a732" stroke-width="0.7" stroke-dasharray="3 2"/>
          <line x1="{{ X2 + W }}" y1="{{ YT + FH + H2 }}" x2="{{ RX2 + 2 }}" y2="{{ YT + FH + H2 }}" stroke="#f0a732" stroke-width="0.7" stroke-dasharray="3 2"/>
          <line x1="{{ RX2 }}" y1="{{ YT + FH }}" x2="{{ RX2 }}" y2="{{ YT + FH + H2 }}" stroke="#f0a732" stroke-width="1" marker-start="url(#ah)" marker-end="url(#ah)"/>
          <text x="{{ RX2 + 5 }}" y="{{ YT + FH + H2 / 2 + 3 }}" text-anchor="start" font-size="9" fill="#8890a8"
                font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif">{{ neck_profile.thickness_12th_disp }}</text>

        </svg>
      </div>
      {% endif %}

    </div>

    <div class="footer">lespaulpedia</div>
  </div>
</body>
</html>
